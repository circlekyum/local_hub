# Example environment variables for backend
# Copy this file to .env and fill values before running locally

# OpenAI API key for chat features (leave empty if not using OpenAI)
OPENAI_API_KEY=

# SQLite database path for community posts (relative to backend/ by default)
DATABASE_PATH=data/community.db

# Region attractions sqlite DB path used by post search (optional)
REGION_DB_PATH=data/region.db

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173

# Selected region (optional)
SELECTED_REGION=서울
# Copy to .env and fill values
OPENAI_API_KEY=
DATABASE_PATH=data/community.db
ATTRACTIONS_DATABASE_PATH=database/seoul_attractions.db
CORS_ORIGINS=http://localhost:5173
REGION_DATA_PATH=data/region_data.json
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
