# Example environment variables for backend
# Copy this file to .env and fill values before running locally

# Copy to .env and fill values
OPENAI_API_KEY=
DATABASE_PATH=data/community.db  # 커뮤니티 데이터베이스(중요!)
ATTRACTIONS_DATABASE_PATH=data/region.db  # 서울 관광지 데이터베이스(중요!)
CORS_ORIGINS=http://localhost:5173  # CORS allowed origins (comma-separated)
SELECTED_REGION=서울
REGION_DATA_PATH=data/region_data.json
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173  # CORS allowed origins (comma-separated)
REGION_DB_PATH=data/region.db  # Region attractions sqlite DB path used by post search (optional)